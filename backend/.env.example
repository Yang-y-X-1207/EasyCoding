# Coding-CLI Backend Configuration

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# LLM Configuration (REQUIRED for AI responses)
ANTHROPIC_API_KEY=sk-ant-xxxxx  # Anthropic Claude API key
LLM_MODEL=claude-sonnet-4-7      # Model to use

# Slack Configuration (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token
# Discord Gateway Intents (513 = GUILD_MESSAGES + MESSAGE_CONTENT)
DISCORD_INTENTS=513

# GitHub (for PR creation)
GITHUB_TOKEN=ghp-xxxxx

# GitLab (for MR creation)
GITLAB_TOKEN=glpat-xxxxx

# Notification
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=xxxxx
EMAIL_FROM=coding-cli@example.com
